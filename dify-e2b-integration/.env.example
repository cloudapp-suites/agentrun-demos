# Dify E2B Sandbox 插件凭证配置
# 在 Dify「工具」→「E2B Sandbox」→「授权」页面填写以下值

# sandbox-manager E2B 兼容 API 地址（管控面）
SANDBOX_MANAGER_API_URL=http://sandbox-manager-service:8000/e2b

# sandbox-manager 数据面地址（Connect RPC / 文件操作）
SANDBOX_DATA_PLANE_URL=http://sandbox-manager-service:8000

# sandbox-manager bearer_token（从 ConfigMap 获取）
# kubectl get configmap sandbox-manager-config -n <namespace> -o yaml | grep bearer_token
API_KEY=your-bearer-token

# 默认沙箱模板（即 ToolServer 名称）
DEFAULT_TEMPLATE_ID=e2b-sandbox
